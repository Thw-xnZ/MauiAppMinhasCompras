<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.EditarProduto"
             Title="{Binding Descricao}">
    
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Salvar" Clicked="ToolbarItem_Clicked"/>
    </ContentPage.ToolbarItems>

   
    <VerticalStackLayout Spacing="10" Padding="10">
        <Label Text="Descrição do Produto"/>
        <Entry x:Name="txtDescricao" Text="{Binding Descricao}" />

        <Label Text="Quantidade:" />
        <Entry x:Name="txtQuantidade" Text="{Binding Quantidade}" Keyboard="Numeric" />

        <Label Text="Preço Und:" />
            <Entry x:Name="txtPreco" Text="{Binding Preco}" Keyboard="Numeric" />

        <Label Text="Categoria:" />
        <Entry x:Name="txtCategoria" Text="{Binding Categoria}"/>
    </VerticalStackLayout>
</ContentPage>